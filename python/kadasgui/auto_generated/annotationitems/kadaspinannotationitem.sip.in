class KadasPinAnnotationItem : QgsAnnotationMarkerItem
{
%Docstring(signature="appended")
Kadas-internal "pin" annotation item.

Subclasses \c :py:class:`QgsAnnotationMarkerItem` and pre-configures the
marker symbol with the standard Kadas pin SVG (anchored at the bottom
tip). Adds two extra text fields, \c name and \c remarks, that are used
by the layer tree for tooltips.

Type id: \c "kadas:pin".
%End

%TypeHeaderCode
#include "kadas/gui/annotationitems/kadaspinannotationitem.h"
%End
  public:
    KadasPinAnnotationItem( const QgsPoint &point = QgsPoint() );

