class KadasAnnotationLayerRegistry : QObject
{
%Docstring(signature="appended")
Process-wide registry of the well-known Kadas \c
:py:class:`QgsAnnotationLayer` instances (Redlining, Symbols, Pictures,
Pins, Routes) and their ids inside the current \c
:py:class:`QgsProject`.

Mirrors the legacy \c KadasItemLayerRegistry but produces vanilla \c
:py:class:`QgsAnnotationLayer` instances. The mapping of \c
StandardLayer to project layer id is persisted in the project XML under
the dedicated \c StandardAnnotationLayers element, so it does not
collide with the legacy \c StandardItemLayers element while both
registries coexist during the migration.
%End

%TypeHeaderCode
#include "kadas/gui/annotationitems/kadasannotationlayerregistry.h"
%End
  public:
    enum class StandardLayer
    {
      RedliningLayer,
      SymbolsLayer,
      PicturesLayer,
      PinsLayer,
      RoutesLayer,
      MssLayer
    };

    static QgsAnnotationLayer *getOrCreateAnnotationLayer( StandardLayer layer );
%Docstring
adding it to the current project on first use.
%End


    static void init();
%Docstring
Connects to project signals; must be called once at app startup.
%End

  protected:
    KadasAnnotationLayerRegistry();

};

