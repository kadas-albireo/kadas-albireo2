class KadasAnnotationItemContext
{
%Docstring(signature="appended")
Bundles the per-call context that \c KadasAnnotationItemController needs
for map-space ↔ item-space transforms.

A \c :py:class:`QgsAnnotationItem` stores its geometry in the CRS of the
\c :py:class:`QgsAnnotationLayer` it belongs to. Map tools in turn work
in the map canvas CRS. Controllers therefore need both pieces of
information to project geometry between the two; this lightweight struct
passes them together. Aligns with QGIS's own annotation tooling, where
the layer is the single source of truth for the item CRS.
%End

%TypeHeaderCode
#include "kadas/gui/annotationitems/kadasannotationitemcontext.h"
%End
  public:
    KadasAnnotationItemContext();
    KadasAnnotationItemContext( QgsAnnotationLayer *layer, const QgsMapSettings &mapSettings );

    QgsAnnotationLayer *layer() const;
%Docstring
Owning annotation layer.
%End

    const QgsMapSettings &mapSettings() const;
%Docstring
Map canvas settings; \c
:py:func:`~KadasAnnotationItemContext.destinationCrs` is the map CRS.
%End

    QgsCoordinateReferenceSystem itemCrs() const;
%Docstring
CRS of the item, i.e. the parent annotation layer's CRS.
%End

};

