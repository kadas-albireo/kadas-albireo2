class KadasShapeCaptureMapTool : QgsMapTool
{
%Docstring(signature="appended")
Lightweight shape-capture map tool.

Captures one of: rectangle, circle (center + radius), circular sector
(center + radius + sweep), polyline, polygon. Rendering relies on
:py:class:`QgsRubberBand`. On completion, emits
:py:func:`~shapeCaptured` with the resulting geometry in the canvas
destination CRS.

The rubber band stays visible after capture until :py:func:`~clear` is
called or a new capture starts; this allows callers (e.g. viewshed) to
keep showing the captured shape while a configuration dialog is open and
to update it via :py:func:`~setCircleRadius` /
:py:func:`~setCapturedGeometry`.
%End

%TypeHeaderCode
#include "kadas/gui/maptools/kadasshapecapturemaptool.h"
%End
  public:
    enum class Shape
    {
      Rectangle,
      Circle,
      Sector,
      Polyline,
      Polygon,
    };

    KadasShapeCaptureMapTool( QgsMapCanvas *canvas, Shape shape );
    ~KadasShapeCaptureMapTool();

    void setShape( Shape shape );
    Shape shape() const;

    void clear();
%Docstring
Removes any rubber band and resets capture state.
%End

    void setCircleRadius( double radius );
%Docstring
Replaces the displayed circle / sector preview (Circle and Sector
modes). New radius is in canvas map units.
%End

    QgsPointXY circleCenter() const;
%Docstring
Center of the last captured circle / sector, or last anchor point.
%End
    double circleRadius() const;

    double sectorStartAngle() const;
%Docstring
Start angle of the last captured sector, in radians CCW from east
(Sector mode).
%End
    double sectorStopAngle() const;
%Docstring
Stop angle of the last captured sector, in radians; stopAngle -
startAngle >= 2*pi means full circle.
%End

    bool isCapturing() const;
%Docstring
True while the user is actively capturing (mid-drag for rect/circle,
mid-vertex-stream for poly).
%End

    void setCapturedPolyline( const QVector<QgsPointXY> &vertices );
%Docstring
Replaces the displayed polyline/polygon preview with the given vertices
in canvas CRS. Used by callers that seed the tool from an externally
picked feature. Does not emit
:py:func:`~KadasShapeCaptureMapTool.shapeCaptured`.
%End

    QgsGeometry previewGeometry() const;
%Docstring
Geometry of the shape currently displayed by the rubber band, in canvas
CRS. While capturing a polyline/polygon, this includes the floating
cursor vertex. Returns an empty geometry if nothing is displayed yet.
%End

    static QgsGeometry circlePolygon( const QgsPointXY &center, double radius, int segments = 64 );
%Docstring
Builds a closed polygon ring approximating a circle. Coordinates are in
the same CRS as ``center``.
%End

    static QgsGeometry sectorPolygon( const QgsPointXY &center, double radius, double startAngle, double stopAngle, int segments = 64 );
%Docstring
Builds a pie-slice polygon (center, arc from ``startAngle`` to
``stopAngle`` in radians CCW from east). A sweep of 2*pi or more yields
a full circle. Coordinates are in the same CRS as ``center``.
%End

    virtual void canvasPressEvent( QgsMapMouseEvent *e );

    virtual void canvasMoveEvent( QgsMapMouseEvent *e );

    virtual void canvasReleaseEvent( QgsMapMouseEvent *e );

    virtual void canvasDoubleClickEvent( QgsMapMouseEvent *e );

    virtual void keyPressEvent( QKeyEvent *e );

    virtual void activate();

    virtual void deactivate();


  signals:
    void shapeCaptured( const QgsGeometry &geometry, const QgsCoordinateReferenceSystem &crs );
    void cleared();
    void previewChanged();
%Docstring
Emitted whenever the displayed shape preview changes (mouse move,
numeric input, programmatic updates).
%End

};

