class KadasMapToolEditAnnotationItem : QgsMapTool
{
%Docstring(signature="appended")
Map tool that creates and/or edits a \c :py:class:`QgsAnnotationItem` on
a \c :py:class:`QgsAnnotationLayer`, driven by a \c
KadasAnnotationItemController.

The tool has two entry modes: - **Edit mode**: started with an existing
``itemId``; clicks on vertices drag them, the styling row in the bottom
bar updates the symbol. - **Create mode**: started with a ``controller``
and a target ``layer``; clicks place vertices for a fresh item, a
right-click / Enter finalizes the part. After finalization, clicks on
existing vertices keep editing them, while clicks on empty canvas start
a brand-new item (single-part).

Last-used styling per geometry kind (marker / line / polygon) is
persisted via \c :py:class:`QgsSettingsEntry` and re-applied to freshly
created items.
%End

%TypeHeaderCode
#include "kadas/gui/maptools/kadasmaptooleditannotationitem.h"
%End
  public:
    KadasMapToolEditAnnotationItem( QgsMapCanvas *canvas, QgsAnnotationLayer *layer, const QString &itemId );
%Docstring
Edit an existing annotation item in place.
%End
    KadasMapToolEditAnnotationItem( QgsMapCanvas *canvas, KadasAnnotationItemController *controller, QgsAnnotationLayer *layer );
%Docstring
Create a new annotation item via ``controller``, then keep editing it.
%End

    virtual void activate();

    virtual void deactivate();


    virtual void canvasPressEvent( QgsMapMouseEvent *e );

    virtual void canvasMoveEvent( QgsMapMouseEvent *e );

    virtual void canvasReleaseEvent( QgsMapMouseEvent *e );

    virtual void canvasDoubleClickEvent( QgsMapMouseEvent *e );

    virtual void keyPressEvent( QKeyEvent *e );


    void setMultipart( bool multipart );
%Docstring
Create-mode: when true, finalized parts accumulate on the same item;
default false.
%End

    void setItemFactory( std::function<QgsAnnotationItem *()> factory );
%Docstring
Create-mode: overrides the controller's
:py:func:`~KadasMapToolEditAnnotationItem.createItem` factory.
%End

    void setExtraTopWidget( QWidget *widget );
%Docstring
Inserts a custom widget into the tool's bottom-bar top row, alongside
the undo / redo / close buttons. Must be called before \c
:py:func:`~KadasMapToolEditAnnotationItem.activate`; ownership transfers
to the bar created at activation. Used by per-item integrations that
need a dedicated control (e.g. the MilX symbol picker button) embedded
in the editor instead of floating over the map.
%End

    QgsAnnotationItem *currentItem() const;
%Docstring
The annotation item the tool is currently driving (may be null).
%End

    void addPoint( const QgsPointXY &pos );
%Docstring
Create-mode: drives the create state machine with an explicit point, as
if the user had left-clicked at ``pos``. No-op in pure edit mode.
%End

  signals:
    void partFinished();
%Docstring
Create-mode: emitted whenever a part is finalized.
%End
    void cleared();
%Docstring
Create-mode: emitted after a fresh item replaces the previous one.
%End

};

